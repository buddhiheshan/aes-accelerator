#####################################################################
#  <Property>                                                       #
#     <obj_type name="inst_name" >                                  #
#       <prop name="name" type=type_name value=val />               #
#       <Attr name="name" type=type_name value=val />               #
#     </obj_type>                                                   #
#  </Property>                                                      #
#  where:                                                           #
#       type is data type: Box, String, Int, PTR, Loc, double, Bits #
#       obj_type are: inst, Design, instTerm, Bump, cell, net       #
#####################################################################
<Properties>
  <Design name="picorv32_axi">
	<prop name="CUT_ROWS" type=Int value=0 />
  </Design>
</Properties>

###########################################################$############################################################################################
#  GlobalNetConnection: <net_name> {-pin|-instanceBasename|-net} <base_name_pattern> -type {pgpin|net|tiehi|tielo} {-all|-module <name>|-region <box>} [-override] #
########################################################################################################################################################
GlobalNetConnection: VDD -pin VDD -instanceBasename * -type pgpin -all
GlobalNetConnection: VSS -pin VSS -instanceBasename * -type pgpin -all
GlobalNetConnection: VDD -pin VPP -instanceBasename * -type pgpin -all
GlobalNetConnection: VSS -pin VBB -instanceBasename * -type pgpin -all
GlobalNetConnection: VDD -pin VDDM -instanceBasename * -type pgpin -all
GlobalNetConnection: VDD -pin DVDD -instanceBasename * -type pgpin -all
GlobalNetConnection: VDD -pin AHVDD -instanceBasename * -type pgpin -all
GlobalNetConnection: VSS -pin DVSS -instanceBasename * -type pgpin -all
GlobalNetConnection: VSS -pin AHVSS -instanceBasename * -type pgpin -all

